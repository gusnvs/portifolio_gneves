# ============================================================================
# Root env for Docker Compose. Copy to ".env" and fill in.
#   cp .env.example .env
# (For local `pnpm dev`, use apps/web/.env instead — see README.)
# ============================================================================

# --- Domain (Caddy) ---------------------------------------------------------
# Your domain for automatic HTTPS, or "localhost" for local testing.
DOMAIN=localhost

# --- Database ---------------------------------------------------------------
# Compose talks to the "db" service by hostname. Keep user/pass/db in sync.
POSTGRES_USER=gn
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=gnportfolio
DATABASE_URL=postgresql://gn:change-this-password@db:5432/gnportfolio?schema=public

# --- Admin (Gustavo) --------------------------------------------------------
# Use a bcrypt hash in production (preferred). ADMIN_PASSWORD is a plain fallback.
# Generate a hash: node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" "yourpass"
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change-me

# --- Session cookie (iron-session) — must be >= 32 chars --------------------
SESSION_SECRET=please-change-this-to-a-long-random-string-32+

# --- Encryption (Send File "vault" mode) ------------------------------------
# base64 of your RSA public key PEM. Generate with: pnpm gen:keys
RSA_PUBLIC_KEY=

# --- Email (Send File delivery via SMTP) ------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Gustavo Neves <noreply@example.com>
# Where "vault" files are delivered (your inbox):
MAIL_TO=you@example.com
